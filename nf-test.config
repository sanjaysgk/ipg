config {

    testsDir "."
    workDir System.getenv("NFT_WORKDIR") ?: ".nf-test"
    configFile "tests/nextflow.config"

    // Do not test upstream nf-core modules / subworkflows in this repo —
    // they are tested in nf-core/modules.
    ignore 'modules/nf-core/**', 'subworkflows/nf-core/**'

    // Default profile for all nf-tests. Extend on the command line with
    // `--profile=+docker` or `--profile=+singularity` on CI and locally.
    profile "test"

    // Re-run tests whenever any of these files change, so caches don't
    // go stale after a config edit.
    triggers \
        'nextflow.config', \
        'nf-test.config', \
        'conf/test.config', \
        'conf/base.config', \
        'conf/modules.config', \
        'tests/nextflow.config', \
        'tests/.nftignore'

    // Loaded plugins:
    //   - nft-utils — essential nf-core helper functions
    //   - nft-bam   — BAM/SAM/CRAM output validation
    //   - nft-vcf   — VCF output validation
    //   - nft-csv   — CSV/TSV output validation (contamination tables etc.)
    //
    // nft-fastq 0.0.1 is INTENTIONALLY NOT LOADED — it ships a Groovy build
    // incompatible with nf-test 0.9.5 and throws
    //   java.lang.AbstractMethodError:
    //   AbstractExtensionMethodCache.getDisablePropertyName()
    // at test-compilation time. We do not do any FASTQ-level content
    // validation in our tests (raw reads pass straight through to STAR);
    // when that plugin releases an incompatible-fix bump we can re-enable it.
    plugins {
        load "nft-utils@0.0.3"
        load "nft-bam@0.6.0"
        load "nft-vcf@1.0.7"
        load "nft-csv@0.1.0"
    }
}
