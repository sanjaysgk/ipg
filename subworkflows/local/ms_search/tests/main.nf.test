nextflow_workflow {

    name "Test Subworkflow MS_SEARCH"
    script "../main.nf"
    workflow "MS_SEARCH"

    tag "subworkflows"
    tag "subworkflows_local"
    tag "ms_search"
    tag "stub"

    // Single-engine path with MS2Rescore skipped: PREPARE_FASTA -> SAGE.
    // cryptic_only DB mode (no canonical append). The rescore/integrate chain
    // (MS2Rescore reads the engine PIN directly) is covered by the module-level
    // stub tests (ms2rescore, integrate_engines). Input carries the per-sample db:
    // [meta, [ms_files], db].
    test("ms_search - sage, cryptic_only, skip ms2rescore - stub") {
        options "-stub"
        when {
            params {
                ms_engines      = 'sage'
                instrument      = 'orbitrap'
                mod_type        = 'mod'
                db_search_mode  = 'cryptic_only'
                skip_ms2rescore = true
            }
            workflow {
                """
                input[0] = Channel.of([ [ id:'test', db:'db.fasta' ], [ file("sample.mzML") ], file("db.fasta") ])
                input[1] = []                                  // canonical (unused in cryptic_only)
                input[2] = [ 'sage' ]
                input[3] = file("${projectDir}/assets/NO_FILE")
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                // linear stub chain (PREPARE_FASTA -> SAGE) -> deterministic versions;
                // snapshot pins the version-emission baseline for the subworkflow
                { assert snapshot(workflow.out.versions).match() }
            )
        }
    }

    // Two samples, two DISTINCT databases: each sample must be searched against
    // its OWN db (per-sample routing), so SAGE runs twice and search_db emits one
    // [meta, tda] per sample. Proves the keyed join, not a single broadcast db.
    test("ms_search - two samples route to two distinct dbs - stub") {
        options "-stub"
        when {
            params {
                ms_engines      = 'sage'
                instrument      = 'orbitrap'
                mod_type        = 'mod'
                db_search_mode  = 'cryptic_only'
                skip_ms2rescore = true
            }
            workflow {
                """
                input[0] = Channel.of(
                    [ [ id:'condA', db:'condA_cryptic.fasta' ], [ file("a1.mzML"), file("a2.mzML") ], file("condA_cryptic.fasta") ],
                    [ [ id:'condB', db:'condB_cryptic.fasta' ], [ file("b1.mzML") ],                  file("condB_cryptic.fasta") ]
                )
                input[1] = []
                input[2] = [ 'sage' ]
                input[3] = file("${projectDir}/assets/NO_FILE")
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                // one prepared search db per sample, each keyed to its own meta
                { assert workflow.out.search_db.size() == 2 },
                { assert workflow.out.search_db.collect { it[0].id }.sort() == ['condA', 'condB'] }
            )
        }
    }

    // Real-data positive control (NOT a stub): searches the committed synthetic
    // spectra (tests/data/spike/synth.mzML) against synth_db.fasta — which
    // carries the single planted cryptic peptide CRYPTICALLY — with comet+sage
    // -> MS2Rescore/mokapot -> INTEGRATE_ENGINES, appended to a tiny canonical.
    // A green run recovers CRYPTICALLY in the integrated peptide table at
    // <=1% FDR, classed cryptic. Needs the engines: run under -profile pixi
    // (comet/sage/mokapot main env; ms2rescore feature env) on a compute node.
    test("ms_search - spike comet+sage recovers planted CRYPTICALLY at <=1% FDR") {
        tag "real_data"
        when {
            params {
                ms_engines             = 'comet,sage'
                instrument             = 'orbitrap'
                mod_type               = 'mod'
                peptide_length         = '9'
                db_search_mode         = 'appended'
                skip_ms2rescore        = false
                skip_integrate_engines = false
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id:'SPIKE', db:'synth_db.fasta' ],
                    [ file("${projectDir}/tests/data/spike/synth.mzML") ],
                    file("${projectDir}/tests/data/spike/synth_db.fasta")
                ])
                input[1] = Channel.value(file("${projectDir}/tests/data/spike/canonical_tiny.fasta"))
                input[2] = [ 'comet', 'sage' ]
                input[3] = file("${projectDir}/assets/NO_FILE")
                """
            }
        }
        then {
            def pep = path(workflow.out.peptides[0][1]).readLines()
            def hdr = pep[0].split('\t') as List
            def pi  = hdr.indexOf('peptide')
            def ci  = hdr.indexOf('class')
            def qi  = hdr.indexOf('peptide_qval_lowest')
            def rows = pep.drop(1).collect { it.split('\t') }
            def hit  = rows.find { it[pi] == 'CRYPTICALLY' }
            assertAll(
                { assert workflow.success },
                // the planted cryptic peptide is recovered ...
                { assert hit != null : 'planted peptide CRYPTICALLY not recovered' },
                // ... classed cryptic, at <=1% FDR ...
                { assert hit[ci] == 'cryptic' },
                { assert (hit[qi] as double) <= 0.01 },
                // ... and it is the only cryptic call (no cryptic FDR blowout)
                { assert rows.count { it[ci] == 'cryptic' } == 1 }
            )
        }
    }
}
