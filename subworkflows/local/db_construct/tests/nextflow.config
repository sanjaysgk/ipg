/*
 * Mirror the production gffread ext.args/ext.prefix so the stub emits a
 * .fasta (the -w flag drives the extension) under a branch-distinct name.
 * Without this the stub defaults to .gff3, gffread_fasta is empty, and the
 * reference translation chain (TT_REFERENCE -> SQUISH) never runs.
 * Bare selectors (not .*:DB_CONSTRUCT:...) because nf-test names the process
 * DB_CONSTRUCT:GFFREAD_REFERENCE with no leading pipeline prefix.
 */
process {
    withName: 'GFFREAD_REFERENCE' {
        ext.args   = '-F -W -w'
        ext.prefix = { "${meta.id}_reference_transcriptome" }
    }
    withName: 'GFFREAD_UNMASKED' {
        ext.args   = '-F -W -w'
        ext.prefix = { "${meta.id}_unmasked_transcriptome" }
    }
    withName: 'GFFREAD_INDEL' {
        ext.args   = '-F -W -w'
        ext.prefix = { "${meta.id}_indel_transcriptome" }
    }
}
