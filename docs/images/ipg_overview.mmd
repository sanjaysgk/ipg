%%metro title: sanjaysgk/ipg — cryptic immunopeptidogenomics
%%metro logo: docs/images/nf-core-ipg_logo_dark.png
%%metro style: dark
%%metro file: fastq_in           | FASTQ
%%metro file: ms_in              | mzML
%%metro file: cryptic_fasta      | FASTA
%%metro file: peptides_out       | TSV
%%metro file: report             | HTML
%%metro line: db_construct       | RNA-seq to cryptic peptide database         | #0570b0
%%metro line: ms_search          | MS search, de novo and integration          | #e63946
%%metro legend: bl

graph LR
    subgraph input_section ["Input"]
        %%metro exit: right | db_construct, ms_search
        samplesheet["SAMPLESHEET_TO_CHANNEL"]
        fastq_in[" "]
        ms_in[" "]

        fastq_in -->|db_construct| samplesheet
        ms_in -->|ms_search| samplesheet
    end

    subgraph db_construct_section ["--step db_construct — RNA-seq to cryptic peptide FASTA"]
        %%metro direction: TB
        %%metro entry: left | db_construct
        %%metro exit: right | db_construct
        align["ALIGN_QC<br/>STAR two-pass + RSeQC"]
        assembly["TRANSCRIPT_ASSEMBLY<br/>StringTie + gffcompare"]
        variants["BAM_PREP + BQSR + MUTECT2<br/>somatic variant calling"]
        db["DB_CONSTRUCT<br/>triple-translate + squish"]
        cryptic_fasta[" "]

        align -->|db_construct| assembly
        align -->|db_construct| variants
        assembly -->|db_construct| db
        variants -->|db_construct| db
        db -->|db_construct| cryptic_fasta
    end

    subgraph ms_search_section ["--step ms_search — identify cryptic peptides"]
        %%metro direction: TB
        %%metro entry: left | ms_search
        %%metro exit: right | ms_search
        prepare_fasta["PREPARE_FASTA<br/>target-decoy database"]
        engines["MSFRAGGER + COMET + SAGE<br/>database search"]
        rescore["MS2RESCORE<br/>rescore + mokapot FDR"]
        integrate["INTEGRATE_ENGINES<br/>1% peptide-level FDR"]
        denovo["INSTANOVO + DENOVO_CLASSIFY<br/>de novo discovery (--run_denovo)"]
        peptides_out[" "]

        prepare_fasta -->|ms_search| engines
        engines -->|ms_search| rescore
        rescore -->|ms_search| integrate
        integrate -->|ms_search| peptides_out
        denovo -->|ms_search| peptides_out
    end

    subgraph downstream_section ["Optional downstream"]
        %%metro direction: TB
        %%metro entry: left | ms_search
        %%metro exit: right | ms_search
        immuno["IMMUNOINFORMATICS<br/>HLA binding + motifs + quant"]
        report_node["CRYPTIC REPORT<br/>per-sample HTML"]
        report[" "]

        immuno -->|ms_search| report_node
        report_node -->|ms_search| report
    end

    %% Cross-section handoffs
    samplesheet -->|db_construct| align
    cryptic_fasta -->|ms_search| prepare_fasta
    cryptic_fasta -->|ms_search| denovo
    samplesheet -->|ms_search| denovo
    peptides_out -->|ms_search| immuno
