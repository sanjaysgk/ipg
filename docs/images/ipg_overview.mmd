%% sanjaysgk/ipg — cryptic immunopeptidogenomics pipeline overview
%% Source of truth for docs/images/ipg_overview.svg. Regenerate the SVG with:
%%   npx -y @mermaid-js/mermaid-cli -i docs/images/ipg_overview.mmd \
%%       -o docs/images/ipg_overview.svg -t dark -b transparent
%% Three independent entry points selected by --step. Solid = core path,
%% dashed = optional (--run_* flag), bold ==> = the cross-step database handoff.
%%{init: {"theme":"dark","flowchart":{"curve":"basis","nodeSpacing":36,"rankSpacing":44,"padding":6}}}%%
flowchart TB
    classDef data fill:#082b45,stroke:#7fb3d5,stroke-width:1px,color:#eaf2f8;
    classDef proc fill:#0f3a57,stroke:#5dade2,stroke-width:1px,color:#eaf2f8;
    classDef opt  fill:#3d3210,stroke:#d4ac0d,stroke-width:1px,color:#fdf6e3,stroke-dasharray:5 3;
    classDef out  fill:#0e3b2e,stroke:#52be80,stroke-width:1.5px,color:#eafaf1;
    classDef dep  fill:#2b2b2b,stroke:#888,stroke-width:1px,color:#cccccc,stroke-dasharray:2 3;

    %% ─────────────────── STEP 1 : db_construct ───────────────────
    subgraph S1 ["1 &nbsp;·&nbsp; --step db_construct &nbsp;—&nbsp; RNA-seq → cryptic peptide FASTA"]
        FQ(["RNA-seq FASTQ<br/>samplesheet"]):::data
        PG["PREPARE_GENOME<br/><i>resolve · index reference</i>"]:::proc
        AQ["ALIGN_QC<br/><i>STAR 2-pass · RSeQC strand</i>"]:::proc
        BP["BAM_PREP<br/><i>merge reps @MarkDuplicates · SplitNCigar</i>"]:::proc
        TA["TRANSCRIPT_ASSEMBLY<br/><i>StringTie · gffcompare</i>"]:::proc
        BQ["BQSR<br/><i>base recalibration</i>"]:::proc
        MT["MUTECT2<br/><i>somatic variant calling</i>"]:::proc
        VC["VCF_CURATE<br/><i>SNV + indel VCFs</i>"]:::proc
        VEP["VCF_ANNOTATE_ALL<br/><i>VEP / snpEff · published only</i>"]:::opt
        DBC["DB_CONSTRUCT<br/><i>mask variants · 3-frame translate · squish</i>"]:::proc
        CF[("cryptic.fasta")]:::out

        FQ --> PG --> AQ --> BP
        BP --> TA --> DBC
        BP --> BQ --> MT --> VC --> DBC
        MT -.-> VEP
        DBC --> CF
    end

    %% ─────────────────── STEP 2 : ms_search ───────────────────
    subgraph S2 ["2 &nbsp;·&nbsp; --step ms_search &nbsp;—&nbsp; identify cryptic peptides"]
        MZ(["Immunopeptidome<br/>mzML / .raw + db"]):::data
        CV["Format convert<br/><i>ThermoRawFileParser / msconvert</i>"]:::proc
        PF["PREPARE_FASTA<br/><i>cryptic + canonical · target-decoy</i>"]:::proc
        EN["Search engines<br/><i>MSFragger · Comet · SAGE · PEAKS</i>"]:::proc
        RS["MS2RESCORE<br/><i>MS2PIP + DeepLC → mokapot</i>"]:::proc
        IN["INTEGRATE_ENGINES<br/><i>class-separated 1% FDR</i>"]:::proc
        PEP[("cryptic peptides")]:::out
        DN["DENOVO <i>(optional)</i><br/><i>InstaNovo → classify · uses cryptic db</i>"]:::opt
        VO["Validation &amp; origin <i>(optional)</i><br/><i>PepQuery2 · ANNOTATE_ORIGIN · ORIGINS</i>"]:::opt
        RI["Reports &amp; immuno <i>(optional)</i><br/><i>CRYPTIC_REPORT · netMHCpan · GibbsCluster · FlashLFQ</i>"]:::opt

        MZ --> CV --> PF --> EN --> RS --> IN --> PEP
        CV -.-> DN
        PEP -.-> VO --> RI
    end

    %% ─────────────────── STEP 3 : post_ms (deprecated) ───────────────────
    subgraph S3 ["3 &nbsp;·&nbsp; --step post_ms &nbsp;—&nbsp; legacy PEAKS-only path (deprecated)"]
        P3(["PEAKS PSMs +<br/>provided references"]):::data
        PM["POST_MS_ANALYSIS<br/><i>db_compare ⇄ origins · two-phase</i>"]:::dep
        P3 --> PM
    end

    %% ─────────────── single cross-step handoff (S1 → S2) ───────────────
    CF ==>|per-sample search db| PF
    PEP ~~~ S3
