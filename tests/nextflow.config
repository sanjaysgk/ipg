/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Base Nextflow config for all nf-tests in sanjaysgk/ipg
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Loaded by nf-test.config (configFile directive). Individual module /
    subworkflow tests may ship their own nextflow.config beside their
    main.nf.test which is loaded on top of this via `config "./nextflow.config"`.
----------------------------------------------------------------------------------------
*/

params {
    // nf-core/modules test data bundle (used by stub tests that need a seed file)
    modules_testdata_base_path   = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'
    // nf-core/test-datasets pipeline-specific data — we reuse rnaseq + sarek
    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/'

    input  = "${projectDir}/assets/samplesheet_test.csv"
    outdir = 'results'
}

process {
    resourceLimits = [
        cpus:   4,
        memory: '14.GB',
        time:   '1.h'
    ]
}

// Anonymous S3 access for public test datasets — avoids requiring AWS
// credentials when tests download reference bundles.
aws.client.anonymous = true
