.nextflow*
work/
data/
!tests/data/
# HepG2 mzMLs + Swiss-Prot FASTA are large (~160 MB total) and fetched
# on demand by bin/build_test_ms_search_bundle.sh; never commit.
tests/data/ms_search/*.mzML
tests/data/ms_search/*.fasta
results/
.DS_Store
testing/
testing*
*.pyc
null/

# AI working memory — never commit
.claude/
CLAUDE.md
# pixi environments
.pixi/*
!.pixi/config.toml

# nf-test artifacts
.nf-test*
.nf-test/

# Pre-built IPG tool binaries — these come from containers/ipg-tools or
# from pixi+local compilation. They are not committed to git. Keep only
# the build_test_bundle.sh script under bin/ tracked.
bin/curate_vcf
bin/revert_headers
bin/alt_liftover
bin/triple_translate
bin/squish
bin/origins
bin/gff3sort
bin/gff3sort.pl
bin/gffread_legacy

# Local-only conf overrides
conf/local.config

# sbatch driver logs + local stub-run artefacts
ipg_*.log
test_stub_results/

# All test run output directories
test_*/

# Test data — large files fetched on demand, never commit
tests/data/ms_search/*.mzXML
tests/data/ms_search/*.pepindex
tests/data/ms_search/*.pin
tests/data/ms_search/*.pepXML
tests/data/ipg-db-constructions/reference/
tests/data/ipg-db-constructions/fastq/
tests/data/ipg-db-constructions/variant_calling/
tests/data/ipg-db-constructions/_prefilter/
tests/data/ipg-db-constructions/samplesheet_test.csv
tests/data/e2e_hepg2_chr22/fastq/
*.bak

# IDE settings
.vscode/
