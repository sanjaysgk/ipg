/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    MS search module config
----------------------------------------------------------------------------------------
*/

process {

    // One search DB is built per DISTINCT cryptic database (keyed by db basename
    // via meta.id), so the combined/target-decoy files are uniquely named and
    // published under a per-db subdir — no collision when several samples carry
    // different databases. Letting ext.prefix fall through to the module default
    // (meta.id) is what makes the filenames unique.
    withName: '.*:MS_SEARCH:COMBINE_FASTA' {
        publishDir = [
            path: { "${params.outdir}/ms_search/fasta/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: '.*:MS_SEARCH:PREPARE_FASTA' {
        publishDir = [
            path: { "${params.outdir}/ms_search/fasta/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: '.*:MS_SEARCH:MSFRAGGER' {
        publishDir = [
            path: { "${params.outdir}/ms_search/msfragger" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

}
