/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    MS search module config
----------------------------------------------------------------------------------------
*/

process {

    // Auto-convert Thermo .raw -> indexed mzML (format 2) so every engine can read
    // the spectra. Published so the converted mzML are reusable across runs (and
    // -resume skips re-conversion). Only .raw inputs hit this; mzML pass through.
    withName: '.*:MS_SEARCH:THERMORAWFILEPARSER' {
        ext.args   = '--format 2'
        publishDir = [
            path: { "${params.outdir}/ms_search/mzML" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.endsWith('.mzML') ? filename : null }
        ]
    }

    // One search DB is built per DISTINCT cryptic database (keyed by db basename
    // via meta.id), so the combined/target-decoy files are uniquely named and
    // published under a per-db subdir — no collision when several samples carry
    // different databases. Letting ext.prefix fall through to the module default
    // (meta.id) is what makes the filenames unique.
    withName: '.*:MS_SEARCH:COMBINE_FASTA' {
        publishDir = [
            path: { "${params.outdir}/ms_search/fasta/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: '.*:MS_SEARCH:PREPARE_FASTA' {
        publishDir = [
            path: { "${params.outdir}/ms_search/fasta/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    // Per-sample compute outputs. All keyed by meta.id (the sample), so a
    // multi-sample run lands each sample's engine/rescore/integrate results under
    // its own ms_search/<sample>/ subtree instead of colliding on shared filenames
    // (e.g. results.sage.tsv, comet.psms.tsv, integrated_peptides.tsv).
    withName: '.*:MS_SEARCH:MSFRAGGER' {
        publishDir = [
            path: { "${params.outdir}/ms_search/${meta.id}/msfragger" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: '.*:MS_SEARCH:COMET' {
        publishDir = [
            path: { "${params.outdir}/ms_search/${meta.id}/comet" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: '.*:MS_SEARCH:SAGE' {
        publishDir = [
            path: { "${params.outdir}/ms_search/${meta.id}/sage" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: '.*:MS_SEARCH:CONVERT_MZML' {
        publishDir = [
            path: { "${params.outdir}/ms_search/${meta.id}/convert" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: '.*:MS_SEARCH:MS2RESCORE_.*' {
        publishDir = [
            path: { "${params.outdir}/ms_search/${meta.id}/ms2rescore" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: '.*:MS_SEARCH:INTEGRATE_ENGINES' {
        publishDir = [
            path: { "${params.outdir}/ms_search/${meta.id}/integrate" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: '.*:MS_SEARCH:PICKED_GROUP_FDR' {
        publishDir = [
            path: { "${params.outdir}/ms_search/${meta.id}/protein_group_fdr" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

}
