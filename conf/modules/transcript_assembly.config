/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    TRANSCRIPT_ASSEMBLY module config (steps 4-5)
----------------------------------------------------------------------------------------
*/

process {

    // -R restricts the reference set to overlapping transcripts only.
    // -V enables verbose output (matches legacy step 05).
    // -C is the load-bearing flag — it tells gffcompare to write the
    // consensus combined.gtf with TCONS_NNNN IDs and class codes. The
    // nf-core gffcompare module declares combined_gtf as `optional: true`,
    // so without -C the channel is empty and DB_CONSTRUCT (which now
    // consumes combined_gtf for the gff3sort -> alt_liftover -> gffread
    // -> triple_translate -> squish chain) sees empty input and the
    // entire downstream chain stalls silently.
    withName: '.*:TRANSCRIPT_ASSEMBLY:GFFCOMPARE' {
        ext.args = '-R -V -C'
    }

}
