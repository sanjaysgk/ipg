/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    DB_CONSTRUCT module config (steps 24-31)
----------------------------------------------------------------------------------------
*/

process {

    // Publish every db_construct output under a per-sample directory
    // (results/db_construct/<sample>/...) rather than the global process-keyed
    // layout, so each sample's cryptic DB + artifacts are self-contained and
    // ms_search can map a sample to its DB by path. meta.id is the unit, so this
    // holds for both the merged (1 DB/condition) and per-rep (1 DB/rep) styles.
    withName: '.*:DB_CONSTRUCT:.*' {
        publishDir = [
            path: { "${params.outdir}/db_construct/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // gffread needs -F (full attributes) and -W (adjust CDS phases) to
    // produce a usable transcriptome FASTA matching the legacy pipeline.
    // The nf-core gffread module already appends `-w ${prefix}.fasta`
    // itself, so do NOT include `-w` in ext.args here. Distinct prefixes
    // for the three branches (unmasked / indel / reference) so the
    // downstream TRIPLE_TRANSLATE branches don't collide on filename.
    withName: '.*:DB_CONSTRUCT:GFFREAD_UNMASKED' {
        ext.args   = '-F -W -w'
        ext.prefix = { "${meta.id}_unmasked_transcriptome" }
    }
    withName: '.*:DB_CONSTRUCT:GFFREAD_INDEL' {
        ext.args   = '-F -W -w'
        ext.prefix = { "${meta.id}_indel_transcriptome" }
    }
    withName: '.*:DB_CONSTRUCT:GFFREAD_REFERENCE' {
        ext.args   = '-F -W -w'
        ext.prefix = { "${meta.id}_reference_transcriptome" }
    }

}
