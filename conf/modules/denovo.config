/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    DE NOVO lane module config (Phase 1a — InstaNovo + classify)
----------------------------------------------------------------------------------------
*/

process {

    withName: '.*:DENOVO:INSTANOVO_PREDICT' {
        publishDir = [
            path: { "${params.outdir}/ms_search/${meta.id}/denovo" },
            mode: params.publish_dir_mode
        ]
    }

    withName: '.*:DENOVO:DENOVO_CLASSIFY' {
        // Raw de novo log-prob confidence filter (Phase 1a; Winnow FDR is layered on later).
        // InstaNovo emits the top peptide in `predictions` and confidence in `log_probs`,
        // which are denovo_classify.py's defaults — only thresholds need passing.
        ext.args = { "--min-log-prob ${params.denovo_min_logprob} --min-length ${params.denovo_min_length} --engine instanovo" }
        publishDir = [
            path: { "${params.outdir}/ms_search/${meta.id}/denovo" },
            mode: params.publish_dir_mode
        ]
    }

}
