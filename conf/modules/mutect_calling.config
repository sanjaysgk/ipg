/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    MUTECT_CALLING module config (steps 17-23)
----------------------------------------------------------------------------------------
*/

process {

    // Mutect2 must be told to produce the f1r2.tar.gz so the downstream
    // LearnReadOrientationModel step has input. Without --f1r2-tar-gz the
    // f1r2 output channel is empty (it is `optional: true` in the module)
    // and the entire mutect_calling -> db_construct chain stalls silently.
    withName: '.*:MUTECT_CALLING:GATK4_MUTECT2' {
        ext.args = { "--f1r2-tar-gz ${meta.id}.f1r2.tar.gz" }
    }

    // CalculateContamination's segmentation output is `optional: true`;
    // it is only emitted when --tumor-segmentation is passed. The legacy
    // pipeline uses tumour-only contamination calling, so we always need
    // it. Without segmentation, FilterMutectCalls's join() upstream goes
    // empty and the entire DB_CONSTRUCT chain stalls silently.
    withName: '.*:MUTECT_CALLING:GATK4_CALCULATECONTAMINATION' {
        ext.args = { "--tumor-segmentation ${meta.id}.segmentation.table" }
    }

    // FilterMutectCalls' default output prefix is `${meta.id}` which
    // collides with the Mutect2 input file `${meta.id}.vcf.gz`. Nextflow
    // excludes input files from the output match set, so the emit fails
    // with "Missing output file(s) *.vcf.gz". Distinct prefix fixes it.
    withName: '.*:MUTECT_CALLING:GATK4_FILTERMUTECTCALLS' {
        ext.prefix = { "${meta.id}.filtered" }
    }

    // Match legacy SelectVariants args: PASS-only + sites-only output.
    // Distinct prefix to avoid input/output filename collision.
    withName: '.*:MUTECT_CALLING:GATK4_SELECTVARIANTS' {
        ext.args   = '--exclude-filtered true --sites-only-vcf-output true'
        ext.prefix = { "${meta.id}.pass" }
    }

}
