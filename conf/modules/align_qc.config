/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    ALIGN_QC module config (steps 1-3)
----------------------------------------------------------------------------------------
*/

process {

    // STAR does NOT auto-detect gzipped input — the nf-core convention is
    // to pass --readFilesCommand via ext.args. --twopassMode Basic matches
    // the legacy cryptic pipeline.
    withName: '.*:ALIGN_QC:STAR_ALIGN' {
        ext.args = '--twopassMode Basic --readFilesCommand zcat --outSAMtype BAM SortedByCoordinate'
    }

    withName: '.*:ALIGN_QC:SAMTOOLS_SORT' {
        ext.prefix = { "${meta.id}.sorted" }
    }

}
