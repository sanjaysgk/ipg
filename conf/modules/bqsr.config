/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    BQSR module config (steps 13-16)
----------------------------------------------------------------------------------------
*/

process {

    // ApplyBQSR defaults to CRAM output; force BAM so the downstream
    // SAMTOOLS_INDEX_RECAL + Mutect2 chain (which expect .bam) work.
    withName: '.*:BQSR:GATK4_APPLYBQSR' {
        ext.suffix = 'bam'
        ext.prefix = { "${meta.id}.recal" }
    }

    // BaseRecalibrator runs twice (before / after); their default output
    // file name is the same and collides when AnalyzeCovariates stages
    // both into one work dir. Differentiate them with ext.prefix.
    withName: '.*:BQSR:BASERECALIBRATOR_FIRST' {
        ext.prefix = { "${meta.id}.recal_before" }
    }
    withName: '.*:BQSR:BASERECALIBRATOR_SECOND' {
        ext.prefix = { "${meta.id}.recal_after" }
    }

    // AnalyzeCovariates needs R + ggplot2 to render the QC PDF. The
    // nf-core gatk4 container bundles R but the local pixi profile
    // does not. The CSV data is still generated even when the R script
    // fails. Treat as QC-only.
    withName: '.*:BQSR:GATK4_ANALYZECOVARIATES' {
        conda         = 'bioconda::gatk4=4.6.2.0 bioconda::gcnvkernel=0.9 conda-forge::r-ggplot2=3.5.2 conda-forge::r-gplots=3.2.0 conda-forge::r-gsalib=2.2.1'
        errorStrategy = 'ignore'
    }

}
