/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    VCF_ANNOTATE_ALL module config (leaf branch — published artifacts only)
----------------------------------------------------------------------------------------
*/

process {

    // VEP stub/real output is ${meta.id}.vcf.gz, which collides with the input
    // VCF; a distinct prefix avoids the "cannot overwrite existing file" error.
    // AlphaMissense plugin is appended only when the tsv is given and requested;
    // the file= value is the staged basename (VEP runs offline in the work dir).
    withName: '.*:VCF_ANNOTATE_ALL:ENSEMBLVEP_VEP' {
        ext.args = {
            def base = '--everything --filter_common --per_gene --total_length --offline --format vcf --vcf'
            params.alphamissense_tsv && params.tools?.contains('alphamissense')
                ? "${base} --plugin AlphaMissense,file=${file(params.alphamissense_tsv).name},cols=all"
                : base
        }
        ext.prefix = { "${meta.id}.vep" }
        publishDir = [ path: { "${params.outdir}/annotation/vep" }, mode: params.publish_dir_mode ]
    }

    withName: '.*:VCF_ANNOTATE_ALL:ENSEMBLVEP_DOWNLOAD' {
        publishDir = [ enabled: false ]
    }

    withName: '.*:VCF_ANNOTATE_ALL:SNPEFF_SNPEFF' {
        ext.prefix = { "${meta.id}.snpeff" }
        publishDir = [ path: { "${params.outdir}/annotation/snpeff" }, mode: params.publish_dir_mode ]
    }

    withName: '.*:VCF_ANNOTATE_ALL:SNPEFF_DOWNLOAD' {
        publishDir = [ enabled: false ]
    }

    withName: '.*:VCF_ANNOTATE_ALL:TABIX_BGZIPTABIX' {
        publishDir = [ path: { "${params.outdir}/annotation" }, mode: params.publish_dir_mode ]
    }

}
