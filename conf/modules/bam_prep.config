/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    BAM_PREP module config (steps 6-12)
----------------------------------------------------------------------------------------
*/

process {

    // Sort by queryname for MergeBamAlignment compatibility.
    withName: '.*:BAM_PREP:SAMTOOLS_SORT' {
        ext.args   = '-n'
        ext.prefix = { "${meta.id}.qnsort" }
    }

    withName: '.*:BAM_PREP:GATK4_FASTQTOSAM' {
        // RG ID must match STAR's --outSAMattrRGline (set to ${meta.id}), else
        // MergeBamAlignment fails READ_GROUP_NOT_FOUND. --SAMPLE_NAME (SM) is
        // tied to ext.prefix in the module, so prefix carries the sample, not
        // the per-rep id: all reps of a sample must share one SM or Mutect2
        // sees multiple samples in the merged BAM. Single-rep meta has no
        // .sample, so it falls back to meta.id, unchanged from before.
        ext.args   = { "--READ_GROUP_NAME ${meta.id} --PLATFORM ILLUMINA" }
        ext.prefix = { "${meta.sample ?: meta.id}.unmapped" }
    }

    withName: '.*:BAM_PREP:GATK4_MARKDUPLICATES' {
        // --READ_NAME_REGEX null disables optical-duplicate detection (legacy
        // step 10). Optical dups are within-lane, so detection is meaningless
        // once reps from different lanes are merged here; duplicates are still
        // marked by position. Also avoids read-name regex warnings.
        ext.args   = '--READ_NAME_REGEX null'
        ext.prefix = { "${meta.id}.markdup.bam" }
    }

    withName: '.*:BAM_PREP:GATK4_SPLITNCIGARREADS' {
        ext.prefix = { "${meta.id}.splitN" }
    }

    // ValidateSamFile is an audit step — it intentionally exits non-zero
    // when it finds SAM validation issues (which are usually expected on
    // RNA-seq aligned BAMs). Don't fail the pipeline on its return code.
    withName: '.*:BAM_PREP:GATK4_VALIDATESAMFILE' {
        ext.args      = '-M SUMMARY --IGNORE MISSING_TAG_NM'
        errorStrategy = 'ignore'
    }

}
