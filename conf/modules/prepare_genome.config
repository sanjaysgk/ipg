/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    PREPARE_GENOME module config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    When --save_reference is true, built/downloaded files are copied to
    ${outdir}/reference/ so they can be reused in future runs.
----------------------------------------------------------------------------------------
*/

process {

    withName: '.*:PREPARE_GENOME:GUNZIP_FASTA' {
        publishDir = [
            path: { "${params.outdir}/reference/genome" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.save_reference
        ]
    }

    withName: '.*:PREPARE_GENOME:GUNZIP_GTF' {
        publishDir = [
            path: { "${params.outdir}/reference/genome" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.save_reference
        ]
    }

    withName: '.*:PREPARE_GENOME:SAMTOOLS_FAIDX' {
        publishDir = [
            path: { "${params.outdir}/reference/genome" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.save_reference
        ]
    }

    withName: '.*:PREPARE_GENOME:GATK4_CREATESEQUENCEDICTIONARY' {
        publishDir = [
            path: { "${params.outdir}/reference/genome" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.save_reference
        ]
    }

    // STAR genome index build is expensive (~32 GB RAM, 30-60 min for GRCh38).
    // --sjdbOverhang 149 matches the ATLANTIS 150 bp reads (read_length - 1).
    withName: '.*:PREPARE_GENOME:STAR_GENOMEGENERATE' {
        ext.args   = '--sjdbOverhang 149'
        memory     = { 36.GB * task.attempt }
        time       = { 2.h  * task.attempt }
        cpus       = 12
        publishDir = [
            path: { "${params.outdir}/reference/genome" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.save_reference
        ]
    }

}
