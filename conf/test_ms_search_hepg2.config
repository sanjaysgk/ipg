/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Test profile — --step ms_search against nf-core/mhcquant HepG2 fixtures
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Exercises the MS_SEARCH subworkflow with real Orbitrap immunopeptidomics
    data from nf-core/test-datasets (branch: mhcquant), original source is
    PRIDE PXD009752. Three HepG2 replicates × 50 MB + human Swiss-Prot FASTA.

    Prerequisites (one-time):
        bash bin/build_test_ms_search_bundle.sh

    Run (Comet + Sage — no MSFragger so no JAR required):
        pixi run nextflow run . -profile pixi,test_ms_search_hepg2

    Run with MSFragger (needs the JAR):
        pixi run nextflow run . -profile pixi,test_ms_search_hepg2 \
            --ms_engines msfragger,comet,sage \
            --msfragger_jar /path/to/MSFragger-4.1.jar

    Expected runtime: 5-10 minutes on a laptop.
----------------------------------------------------------------------------------------
*/

process {
    // Capped to 4 CPUs so MSFragger (process_high, requests 12 × attempt
    // but clamps to resourceLimits.cpus) fits on a small VS-Code node.
    // Run on Monash SLURM with more if you want speed.
    resourceLimits = [
        cpus:   4,
        memory: '32.GB',
        time:   '2.h'
    ]
}

params {
    config_profile_name        = 'MS search test — HepG2'
    config_profile_description = 'nf-core/mhcquant HepG2 fixtures for exercising --step ms_search on real Orbitrap data'

    step             = 'ms_search'
    ms_engines       = 'comet,sage'     // skip MSFragger by default so no licensed JAR is needed
    // ms2rescore unavailable in pixi env (pyopenms/eigen conflict);
    // pipeline still validates PREPARE_FASTA→COMET→SAGE→CONVERT_MZML
    // →MOKAPOT end-to-end. Override to false + use -profile conda if
    // rescoring is needed.
    skip_ms2rescore  = true
    instrument   = 'orbitrap'
    mod_type     = 'mod'
    peptide_length = '8-12'

    // Paths set up by bin/build_test_ms_search_bundle.sh. Default to the
    // 500-protein mini FASTA so Sage's in-memory index stays <16 GB. Set
    // --search_fasta on the CLI to override with the full Swiss-Prot for
    // realistic benchmarks.
    test_bundle  = "${projectDir}/tests/data/ms_search"
    ms_input     = "${params.test_bundle}/samplesheet.csv"
    search_fasta = "${params.test_bundle}/human_swissprot_mini.fasta"

    // Disable genome auto-fetch — ms_search doesn't need the RNA-seq bundle.
    genome = null
}
