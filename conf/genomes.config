/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    IPG-specific genome reference configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Extends the standard nf-core iGenomes entries with GATK variant calling
    resources and GENCODE v44 annotations required by the cryptic peptide
    pipeline. Loaded AFTER igenomes.config so that entries here augment (and
    where keys overlap, override) the iGenomes defaults.

    Public data sources:
        - GENCODE v44:  https://www.gencodegenes.org/human/release_44.html
        - Broad hg38:   https://console.cloud.google.com/storage/browser/genomics-public-data/resources/broad/hg38/v0
        - RSeQC BED:    https://sourceforge.net/projects/rseqc/files/BED/Human_Homo_sapiens/
----------------------------------------------------------------------------------------
*/

params {
    genomes {
        'GRCh38' {
            // ---- GENCODE v44 primary assembly (overrides iGenomes NCBI defaults) ----
            fasta       = 'https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_44/GRCh38.primary_assembly.genome.fa.gz'
            gtf         = 'https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_44/gencode.v44.primary_assembly.annotation.gtf.gz'

            // ---- RSeQC gene model BED (GENCODE v44 matched) ----
            rseqc_bed   = 'https://sourceforge.net/projects/rseqc/files/BED/Human_Homo_sapiens/hg38_GENCODE_V44_Basic.bed.gz/download'

            // ---- GATK hg38 variant calling resources (Broad public GCS bucket) ----
            dbsnp               = 'https://storage.googleapis.com/genomics-public-data/resources/broad/hg38/v0/Homo_sapiens_assembly38.dbsnp138.vcf.gz'
            dbsnp_tbi           = 'https://storage.googleapis.com/genomics-public-data/resources/broad/hg38/v0/Homo_sapiens_assembly38.dbsnp138.vcf.gz.tbi'
            known_indels        = 'https://storage.googleapis.com/genomics-public-data/resources/broad/hg38/v0/Homo_sapiens_assembly38.known_indels.vcf.gz'
            known_indels_tbi    = 'https://storage.googleapis.com/genomics-public-data/resources/broad/hg38/v0/Homo_sapiens_assembly38.known_indels.vcf.gz.tbi'
            mills               = 'https://storage.googleapis.com/genomics-public-data/resources/broad/hg38/v0/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz'
            mills_tbi           = 'https://storage.googleapis.com/genomics-public-data/resources/broad/hg38/v0/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz.tbi'
            germline_resource     = 'https://storage.googleapis.com/genomics-public-data/resources/broad/hg38/v0/small_exac_common_3.hg38.vcf.gz'
            germline_resource_tbi = 'https://storage.googleapis.com/genomics-public-data/resources/broad/hg38/v0/small_exac_common_3.hg38.vcf.gz.tbi'
        }
    }
}
