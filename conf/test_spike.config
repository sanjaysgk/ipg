/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Synthetic spike-in positive control for --step ms_search
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Known-answer test: searches committed theoretical b/y-ion spectra (tests/data/spike)
    against a tiny FASTA that contains a single planted cryptic peptide, CRYPTICALLY.
    A green run recovers CRYPTICALLY in the integrated peptide table at <=1% FDR; a red
    run localises the broken link in PREPARE_FASTA -> COMET/SAGE -> MOKAPOT ->
    MS2RESCORE -> INTEGRATE_ENGINES.

    Real execution (needs the tools, ~5 min) — pair with -profile pixi:

        pixi run nextflow run . -profile pixi,test_spike --outdir results_spike

    MSFragger is omitted by default (its JAR is academic-license-gated and cannot be
    committed/downloaded in CI). Add it when a JAR is available:

        ... -profile pixi,test_spike --ms_engines comet,sage,msfragger \\
            --msfragger_jar /path/to/MSFragger-4.2.jar
----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus:   6,
        memory: '48.GB',
        time:   '2.h'
    ]
}

params {
    config_profile_name        = 'Synthetic spike-in positive control'
    config_profile_description = 'Known-answer ms_search test recovering the planted peptide CRYPTICALLY'

    step                   = 'ms_search'

    // Committed micro-fixtures (tests/data/spike). ms_file in the samplesheet is
    // relative and resolved against the samplesheet directory by nf-schema.
    ms_input               = "${projectDir}/tests/data/spike/samplesheet_ms.csv"
    search_fasta           = "${projectDir}/tests/data/spike/synth_db.fasta"

    // Tiny committed canonical (4 proteins) so appended-mode (the default) is
    // exercised without downloading the full UP000005640 proteome — which
    // bloats the SAGE fragment index under non-specific digestion and OOMs.
    canonical_fasta        = "${projectDir}/tests/data/spike/canonical_tiny.fasta"

    // Comet + Sage by default (MSFragger added on the command line with a JAR).
    ms_engines             = 'comet,sage'
    skip_ms2rescore        = false
    skip_integrate_engines = false

    instrument             = 'orbitrap'
    mod_type               = 'mod'
    peptide_length         = '9'

    // ── db_construct phase (run with --step db_construct) ──
    // Two-phase like test_e2e_hepg2_chr22: phase 1 builds the cryptic FASTA from a
    // tiny synthetic genome whose transcript encodes CRYPTICALLY in a non-canonical
    // frame; phase 2 (default) searches the synth MS spectra. Genome fixtures are
    // generated by tests/data/spike/make_synth_genome.py (--out-dir .../genome).
    spike_genome           = "${projectDir}/tests/data/spike/genome"
    input                  = "${params.spike_genome}/samplesheet_rnaseq.csv"
    fasta                  = "${params.spike_genome}/genome.fa"
    gtf                    = "${params.spike_genome}/genes.gtf"
    rseqc_bed              = "${params.spike_genome}/genes.bed"
    dbsnp                  = "${params.spike_genome}/dbsnp.vcf.gz"
    dbsnp_tbi              = "${params.spike_genome}/dbsnp.vcf.gz.tbi"
    known_indels           = "${params.spike_genome}/known_indels.vcf.gz"
    known_indels_tbi       = "${params.spike_genome}/known_indels.vcf.gz.tbi"
    mills                  = "${params.spike_genome}/mills.vcf.gz"
    mills_tbi              = "${params.spike_genome}/mills.vcf.gz.tbi"
    germline_resource      = "${params.spike_genome}/germline_resource.vcf.gz"
    germline_resource_tbi  = "${params.spike_genome}/germline_resource.vcf.gz.tbi"

    genome = null
}
