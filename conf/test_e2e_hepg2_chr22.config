/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    sanjaysgk/ipg: E2E HepG2 chr22 test config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    End-to-end test using ENCODE HepG2 polyA+ RNA-seq (chr22 subset) +
    nf-core/mhcquant HepG2 immunopeptidome MS data.

    Runs in two phases:
      Phase 1:  nextflow run . -profile pixi,test_e2e_hepg2_chr22 --step db_construct
      Phase 2:  nextflow run . -profile pixi,test_e2e_hepg2_chr22 --step ms_search \
                    --search_fasta test_e2e_hepg2/db_construct/squish/HepG2_chr22_cryptic.fasta

    Source:
      RNA-seq : ENCODE ENCSR985KAT rep1 (Graveley lab, UConn) → chr22 subset
      MS data : nf-core/mhcquant HepG2 (PXD009752) → double-converted clean mzML

    Build fixture:  bash bin/build_e2e_hepg2_chr22.sh

    Validated 2026-04-20:
      Phase 1: 31 processes, 5.5 min, 3354 cryptic ORFs
      Phase 2: 6 processes, 10 min, ~130 cryptic peptide PSMs per engine
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    config_profile_name        = 'E2E HepG2 chr22 test'
    config_profile_description = 'Full pipeline test: db_construct → ms_search on HepG2 chr22'

    // Locate fixture directories
    e2e_bundle = "${projectDir}/tests/data/e2e_hepg2_chr22"
    db_bundle  = "${projectDir}/tests/data/ipg-db-constructions"
    ms_bundle  = "${projectDir}/tests/data/ms_search"

    // ── Phase 1: db_construct inputs ──
    input          = "${params.e2e_bundle}/samplesheet_rnaseq.csv"
    fasta          = "${params.db_bundle}/reference/GRCh38.chr22.fa"
    gtf            = "${params.db_bundle}/reference/gencode.v44.chr22.gtf"
    star_index     = "${params.db_bundle}/reference/star_index_chr22"
    rseqc_bed      = "${params.db_bundle}/reference/gencode_assembly.chr22.bed"
    dbsnp          = "${params.db_bundle}/variant_calling/dbsnp138.chr22.vcf.gz"
    dbsnp_tbi      = "${params.db_bundle}/variant_calling/dbsnp138.chr22.vcf.gz.tbi"
    known_indels   = "${params.db_bundle}/variant_calling/known_indels.chr22.vcf.gz"
    known_indels_tbi = "${params.db_bundle}/variant_calling/known_indels.chr22.vcf.gz.tbi"
    mills          = "${params.db_bundle}/variant_calling/Mills.chr22.vcf.gz"
    mills_tbi      = "${params.db_bundle}/variant_calling/Mills.chr22.vcf.gz.tbi"
    germline_resource     = "${params.db_bundle}/variant_calling/small_exac_common_3.chr22.vcf.gz"
    germline_resource_tbi = "${params.db_bundle}/variant_calling/small_exac_common_3.chr22.vcf.gz.tbi"

    // ── Phase 2: ms_search inputs ──
    ms_input       = "${params.e2e_bundle}/samplesheet_ms.csv"
    // search_fasta: override on CLI with cryptic FASTA from Phase 1 output,
    // or use Swiss-Prot mini as default for standalone ms_search testing
    search_fasta   = "${params.ms_bundle}/human_swissprot_mini.fasta"
    ms_engines     = 'msfragger,comet,sage'
    msfragger_mem  = 8
    skip_ms2rescore        = true
    skip_integrate_engines = true
}

// Cap resources for login-node / CI testing (6 CPUs on M3 login)
process {
    withLabel:process_high   { cpus = 6; memory = '16.GB' }
    withLabel:process_medium { cpus = 4; memory = '8.GB'  }
}
