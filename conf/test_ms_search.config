/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Test profile for --step ms_search
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Intended for nf-test / -stub runs that exercise the ms_search subworkflow
    without requiring a real mzML + licensed MSFragger JAR. Pair with -stub to
    validate DSL wiring:

        nextflow run . -profile test_ms_search,pixi -stub \\
            --outdir test_ms_search_results

    Real-data validation should instead extend this profile with explicit
    --ms_input / --msfragger_jar paths on the command line.
----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus:   4,
        memory: '14.GB',
        time:   '1.h'
    ]
}

params {
    config_profile_name        = 'MS search test profile'
    config_profile_description = 'Stub-only profile exercising --step ms_search wiring'

    step = 'ms_search'

    // Placeholder sentinels — sufficient for -stub runs. Override on the command
    // line with real paths for non-stub validation.
    test_bundle    = '/fs04/scratch2/xy86/sanjay/ipg-test-data'
    ms_input       = "${params.test_bundle}/ms_samplesheet.csv"
    search_fasta   = "${params.test_bundle}/reference/GRCh38.chr22.fa"
    msfragger_jar  = "${params.test_bundle}/MSFragger-stub.jar"

    ms_engines     = 'msfragger,comet,sage'
    instrument     = 'orbitrap'
    mod_type       = 'mod'
    peptide_length = '9'

    genome = null
}
