/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Multi-sample / multi-rep db_construct stress test
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    2 conditions (SPIKE_A, SPIKE_B) x 3 reps each against the tiny synthetic
    genome. Exercises BOTH merge axes in one run:
      - within-sample: 3 reps -> rg1/rg2/rg3 -> merged at MarkDuplicates, then the
        single merged BAM feeds both transcript assembly and variant calling
      - across-sample: 2 conditions must each reach SQUISH -> 2 cryptic DBs
    A green run produces a cryptic.fasta for BOTH SPIKE_A and SPIKE_B. If only
    one appears, a sample was silently dropped (e.g. a non-broadcast reference
    channel starving the 2nd sample) — the db_construct completeness guard
    turns that into a hard error instead of a quiet partial result.

        pixi run nextflow run . -profile pixi,test_spike_multirep --outdir results_multirep
----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus:   6,
        memory: '12.GB',
        time:   '2.h'
    ]
}

params {
    config_profile_name        = 'Multi-sample db_construct stress test'
    config_profile_description = '2 conditions x 3 reps — rep merge + multi-sample broadcast + drop guard'

    step                  = 'db_construct'

    spike_genome          = "${projectDir}/tests/data/spike/genome"
    input                 = "${params.spike_genome}/samplesheet_rnaseq_multirep.csv"
    fasta                 = "${params.spike_genome}/genome.fa"
    gtf                   = "${params.spike_genome}/genes.gtf"
    rseqc_bed             = "${params.spike_genome}/genes.bed"
    dbsnp                 = "${params.spike_genome}/dbsnp.vcf.gz"
    dbsnp_tbi             = "${params.spike_genome}/dbsnp.vcf.gz.tbi"
    known_indels          = "${params.spike_genome}/known_indels.vcf.gz"
    known_indels_tbi      = "${params.spike_genome}/known_indels.vcf.gz.tbi"
    mills                 = "${params.spike_genome}/mills.vcf.gz"
    mills_tbi             = "${params.spike_genome}/mills.vcf.gz.tbi"
    germline_resource     = "${params.spike_genome}/germline_resource.vcf.gz"
    germline_resource_tbi = "${params.spike_genome}/germline_resource.vcf.gz.tbi"

    // Exercise the full variant branches (FARM unmasked/indel) — the part of
    // the DAG where the multi-sample broadcast gap drops the 2nd sample.
    include_variant_peptides = true

    genome = null
}
