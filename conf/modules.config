/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    withName: FASTQC {
        ext.args = '--quiet'
    }

    withName: 'MULTIQC' {
        ext.args   = { params.multiqc_title ? "--title \"$params.multiqc_title\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // ALIGN_QC (steps 1-3)
    //

    // STAR does NOT auto-detect gzipped input — the nf-core convention is
    // to pass --readFilesCommand via ext.args. --twopassMode Basic matches
    // the legacy cryptic pipeline.
    withName: '.*:ALIGN_QC:STAR_ALIGN' {
        ext.args = '--twopassMode Basic --readFilesCommand zcat --outSAMtype BAM SortedByCoordinate'
    }

    withName: '.*:ALIGN_QC:SAMTOOLS_SORT' {
        ext.prefix = { "${meta.id}.sorted" }
    }

    //
    // BAM_PREP (steps 6-12)
    //

    // Sort by queryname for MergeBamAlignment compatibility.
    withName: '.*:BAM_PREP:SAMTOOLS_SORT' {
        ext.args   = '-n'
        ext.prefix = { "${meta.id}.qnsort" }
    }

    withName: '.*:BAM_PREP:GATK4_FASTQTOSAM' {
        // RG ID must match STAR's --outSAMattrRGline (which the nf-core
        // star/align module sets to ${meta.id} by default), otherwise
        // MergeBamAlignment + MarkDuplicates fail with READ_GROUP_NOT_FOUND.
        ext.args   = { "--READ_GROUP_NAME ${meta.id} --PLATFORM ILLUMINA" }
        ext.prefix = { "${meta.id}.unmapped" }
    }

    withName: '.*:BAM_PREP:GATK4_MARKDUPLICATES' {
        ext.prefix = { "${meta.id}.markdup.bam" }
    }

    withName: '.*:BAM_PREP:GATK4_SPLITNCIGARREADS' {
        ext.prefix = { "${meta.id}.splitN" }
    }

    // ValidateSamFile is an audit step — it intentionally exits non-zero
    // when it finds SAM validation issues (which are usually expected on
    // RNA-seq aligned BAMs). Don't fail the pipeline on its return code.
    withName: '.*:BAM_PREP:GATK4_VALIDATESAMFILE' {
        errorStrategy = 'ignore'
    }

    //
    // BQSR (steps 13-16)
    //

    // ApplyBQSR defaults to CRAM output; force BAM so the downstream
    // SAMTOOLS_INDEX_RECAL + Mutect2 chain (which expect .bam) work.
    withName: '.*:BQSR:GATK4_APPLYBQSR' {
        ext.suffix = 'bam'
        ext.prefix = { "${meta.id}.recal" }
    }

    // BaseRecalibrator runs twice (before / after); their default output
    // file name is the same and collides when AnalyzeCovariates stages
    // both into one work dir. Differentiate them with ext.prefix.
    withName: '.*:BQSR:BASERECALIBRATOR_FIRST' {
        ext.prefix = { "${meta.id}.recal_before" }
    }
    withName: '.*:BQSR:BASERECALIBRATOR_SECOND' {
        ext.prefix = { "${meta.id}.recal_after" }
    }

    // AnalyzeCovariates needs R + ggplot2 to render the QC PDF. The
    // nf-core gatk4 container bundles R but the local pixi profile
    // does not. The CSV data is still generated even when the R script
    // fails. Treat as QC-only.
    withName: '.*:BQSR:GATK4_ANALYZECOVARIATES' {
        errorStrategy = 'ignore'
    }

    //
    // MUTECT_CALLING (steps 17-23)
    //

    // Mutect2 must be told to produce the f1r2.tar.gz so the downstream
    // LearnReadOrientationModel step has input. Without --f1r2-tar-gz the
    // f1r2 output channel is empty (it is `optional: true` in the module)
    // and the entire mutect_calling -> db_construct chain stalls silently.
    withName: '.*:MUTECT_CALLING:GATK4_MUTECT2' {
        ext.args = { "--f1r2-tar-gz ${meta.id}.f1r2.tar.gz" }
    }

    // CalculateContamination's segmentation output is `optional: true`;
    // it is only emitted when --tumor-segmentation is passed. The legacy
    // pipeline uses tumour-only contamination calling, so we always need
    // it. Without segmentation, FilterMutectCalls's join() upstream goes
    // empty and the entire DB_CONSTRUCT chain stalls silently.
    withName: '.*:MUTECT_CALLING:GATK4_CALCULATECONTAMINATION' {
        ext.args = { "--tumor-segmentation ${meta.id}.segmentation.table" }
    }

    // FilterMutectCalls' default output prefix is `${meta.id}` which
    // collides with the Mutect2 input file `${meta.id}.vcf.gz`. Nextflow
    // excludes input files from the output match set, so the emit fails
    // with "Missing output file(s) *.vcf.gz". Distinct prefix fixes it.
    withName: '.*:MUTECT_CALLING:GATK4_FILTERMUTECTCALLS' {
        ext.prefix = { "${meta.id}.filtered" }
    }

    // Match legacy SelectVariants args: PASS-only + sites-only output.
    // Distinct prefix to avoid input/output filename collision.
    withName: '.*:MUTECT_CALLING:GATK4_SELECTVARIANTS' {
        ext.args   = '--exclude-filtered true --sites-only-vcf-output true'
        ext.prefix = { "${meta.id}.pass" }
    }

    //
    // DB_CONSTRUCT (steps 24-31)
    //

    // gffread needs -F (full attributes) and -W (adjust CDS phases) to
    // produce a usable transcriptome FASTA matching the legacy pipeline.
    // The nf-core gffread module already appends `-w ${prefix}.fasta`
    // itself, so do NOT include `-w` in ext.args here. Distinct prefixes
    // for the three branches (unmasked / indel / reference) so the
    // downstream TRIPLE_TRANSLATE branches don't collide on filename.
    withName: '.*:DB_CONSTRUCT:GFFREAD_UNMASKED' {
        ext.args   = '-F -W -w'
        ext.prefix = { "${meta.id}_unmasked_transcriptome" }
    }
    withName: '.*:DB_CONSTRUCT:GFFREAD_INDEL' {
        ext.args   = '-F -W -w'
        ext.prefix = { "${meta.id}_indel_transcriptome" }
    }
    withName: '.*:DB_CONSTRUCT:GFFREAD_REFERENCE' {
        ext.args   = '-F -W -w'
        ext.prefix = { "${meta.id}_reference_transcriptome" }
    }

}
