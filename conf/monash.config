/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for the Monash M3 HPC cluster
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    SLURM executor, xy86 account, 'comp' partition. Uses Singularity containers
    — matches the 'singularity' profile on top. Intended to be layered with
    the `test` or `real-sample` profile on Monash compute nodes:

        nextflow run sanjaysgk/ipg \
            -profile monash,singularity,test \
            --outdir results

    For runs against full-scale reference and real samples:

        nextflow run sanjaysgk/ipg \
            -profile monash,singularity \
            --input samplesheet.csv \
            --fasta /home/chenli/xy86_scratch/sanjay/ATLANTIS/RNAseq/Analysis/Cryptic/GRCh38/GRCh38.primary_assembly.genome.fa \
            --fasta_fai /home/chenli/.../GRCh38.primary_assembly.genome.fa.fai \
            --fasta_dict /home/chenli/.../GRCh38.primary_assembly.genome.dict \
            --star_index /home/chenli/.../human_genome_index_GRCh38 \
            --gtf /home/chenli/.../gencode.v44.primary_assembly.annotation.gtf \
            ... \
            --outdir results
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Monash M3 (xy86)'
    config_profile_description = 'Monash Massive M3 HPC cluster — SLURM executor on the comp partition under the xy86 project'
    config_profile_contact     = 'Sanjay SG Krishna <sanjay.sondekoppagopalakrishna@monash.edu>'
    config_profile_url         = 'https://docs.massive.org.au/'
}

process {
    executor         = 'slurm'
    queue            = 'comp'
    clusterOptions   = '--account=xy86'

    // Conservative defaults; nf-core module labels (process_single/low/medium/high)
    // are respected via conf/base.config resource-limit rules.
    resourceLimits = [
        cpus:   24,
        memory: '180.GB',
        time:   '24.h'
    ]

    // Cache modules locally so concurrent jobs don't race on /home singularity cache
    errorStrategy = { task.attempt <= 3 ? 'retry' : 'finish' }
    maxRetries    = 3
}

// Singularity is the expected runtime on Monash M3 compute nodes.
singularity {
    enabled      = true
    autoMounts   = true
    // Cache images in the xy86 scratch area so they survive between sessions
    // and are shared across users in the project.
    cacheDir     = "/fs04/scratch2/xy86/singularity_cache"
    pullTimeout  = '60.m'
}

// Disable Docker / other engines so -profile monash is unambiguous
docker.enabled      = false
podman.enabled      = false
shifter.enabled     = false
charliecloud.enabled = false

// Default work directory on fast xy86 scratch storage. Users can still
// override with -w or --workdir on the command line.
workDir = '/fs04/scratch2/xy86/nextflow_work'
