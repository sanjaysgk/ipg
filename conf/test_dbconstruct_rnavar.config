/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    rnavar chr22 db_construct e2e test — PROVIDED references
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Unlike test_spike_multirep (which BUILDS fai/dict/star -> value channels),
    this provides every reference explicitly, reproducing the real MDA-MB-231
    run's channel topology. That is the case the prepare_genome broadcast fix
    must hold for: combine()-built reference channels are queue channels even
    when provided, so without .first() they starve all but one sample.

    Bundle + prepped data are staged on scratch2 (not committed) by:
        pixi run python scripts/prep_rnavar_dbconstruct_testdata.py \
            --bundle <rnavar_bundle> --out <rnavar_bundle>/dbconstruct

    Run (merged = 2 DBs; override --input for the 6-DB per-rep sheet):
        pixi run nextflow run . -profile pixi,singularity,test_dbconstruct_rnavar \
            --outdir results_rnavar
----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus:   6,
        memory: '12.GB',
        time:   '2.h'
    ]
}

params {
    config_profile_name        = 'rnavar chr22 db_construct e2e (provided refs)'
    config_profile_description = 'Provided-ref topology; 2 conditions x 3 reps -> 2 DBs merged / 6 per-rep'

    step = 'db_construct'

    rnavar_bundle = '/fs04/scratch2/xy86/sanjay/ATLANTIS/RNAseq/Analysis/Cryptic/test-datasets/rnavar'
    rnavar_prep   = "${params.rnavar_bundle}/dbconstruct"

    input = "${params.rnavar_prep}/samplesheet_rnavar_merged.csv"

    // Provided references -> queue topology (the real-run case)
    fasta      = "${params.rnavar_bundle}/genome/genome.fasta"
    fasta_fai  = "${params.rnavar_bundle}/genome/genome.fasta.fai"
    fasta_dict = "${params.rnavar_bundle}/genome/genome.dict"
    gtf        = "${params.rnavar_bundle}/genome/genome.gtf"
    star_index = "${params.rnavar_prep}/star"
    rseqc_bed  = "${params.rnavar_prep}/genes.bed"

    dbsnp                 = "${params.rnavar_bundle}/genome/vcf/dbsnp_146.hg38.vcf.gz"
    dbsnp_tbi             = "${params.rnavar_bundle}/genome/vcf/dbsnp_146.hg38.vcf.gz.tbi"
    known_indels          = "${params.rnavar_prep}/known_indels.vcf.gz"
    known_indels_tbi      = "${params.rnavar_prep}/known_indels.vcf.gz.tbi"
    mills                 = "${params.rnavar_bundle}/genome/vcf/mills_and_1000G.indels.vcf.gz"
    mills_tbi             = "${params.rnavar_bundle}/genome/vcf/mills_and_1000G.indels.vcf.gz.tbi"
    germline_resource     = "${params.rnavar_prep}/germline_af_only.vcf.gz"
    germline_resource_tbi = "${params.rnavar_prep}/germline_af_only.vcf.gz.tbi"

    // Exercise the full variant branches (unmasked + indel)
    include_variant_peptides = true

    genome = null
}
