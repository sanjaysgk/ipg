/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Full-size test profile
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

    Usage:
        nextflow run sanjaysgk/ipg -profile test_full,<docker/singularity> --outdir <OUTDIR>

    Until production-scale full-size test data is published, test_full
    inherits everything from the chr22 test profile so that
    `nf-core pipelines download` (which runs `nextflow inspect` against
    both test and test_full to enumerate containers) can resolve params.
----------------------------------------------------------------------------------------
*/

includeConfig 'test.config'

params {
    config_profile_name        = 'Full test profile'
    config_profile_description = 'Full-size run — currently mirrors the chr22 test bundle until production-scale data is published.'
}
