/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run sanjaysgk/ipg -profile test,singularity --outdir results

    The test profile pulls subset inputs from the upstream nf-core/test-datasets
    repository:
        - `rnaseq`  branch — chr22 FASTQ reads + GRCh38 chr22 FASTA/FAI/DICT + GTF + BED
        - `sarek`   branch — chr22-subset dbSNP / known indels / Mills / small_exac VCFs
    so we don't ship any test data in this repo (see .claude/DECISIONS.md ADR-004).
----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus:   4,
        memory: '14.GB',
        time:   '1.h'
    ]
}

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal chr22 subset dataset to check pipeline function'

    // Pull everything from the upstream nf-core/test-datasets repo via the
    // base path declared in nextflow.config:
    //     pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/'
    // We reference the rnaseq and sarek branches directly by tail-joining.

    // --- Samplesheet (paired-end chr22 subset from nf-core/rnaseq) ---
    input = "${projectDir}/assets/samplesheet_test.csv"

    // --- Reference genome bundle (nf-core/test-datasets:rnaseq) ---
    fasta       = "${params.pipelines_testdata_base_path}rnaseq/reference/genome.fasta"
    fasta_fai   = "${params.pipelines_testdata_base_path}rnaseq/reference/genome.fasta.fai"
    fasta_dict  = "${params.pipelines_testdata_base_path}rnaseq/reference/genome.dict"
    gtf         = "${params.pipelines_testdata_base_path}rnaseq/reference/genes.gtf.gz"
    star_index  = "${params.pipelines_testdata_base_path}rnaseq/reference/star.tar.gz"

    // RSeQC gene model BED (chr22 subset)
    rseqc_bed   = "${params.pipelines_testdata_base_path}rnaseq/reference/hg19_RefSeq.bed"

    // --- BQSR known-sites VCFs (nf-core/test-datasets:sarek, chr22 subsets) ---
    dbsnp                  = "${params.pipelines_testdata_base_path}sarek/reference/dbsnp_146.hg38.vcf.gz"
    dbsnp_tbi              = "${params.pipelines_testdata_base_path}sarek/reference/dbsnp_146.hg38.vcf.gz.tbi"
    known_indels           = "${params.pipelines_testdata_base_path}sarek/reference/Homo_sapiens_assembly38.known_indels.vcf.gz"
    known_indels_tbi       = "${params.pipelines_testdata_base_path}sarek/reference/Homo_sapiens_assembly38.known_indels.vcf.gz.tbi"
    mills                  = "${params.pipelines_testdata_base_path}sarek/reference/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz"
    mills_tbi              = "${params.pipelines_testdata_base_path}sarek/reference/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz.tbi"

    // Mutect2 + GetPileupSummaries germline resource
    germline_resource      = "${params.pipelines_testdata_base_path}sarek/reference/small_exac_common_3.hg38.vcf.gz"
    germline_resource_tbi  = "${params.pipelines_testdata_base_path}sarek/reference/small_exac_common_3.hg38.vcf.gz.tbi"

    // Genome builder auto-fetch is disabled — the pipeline expects explicit paths.
    genome = null
}
