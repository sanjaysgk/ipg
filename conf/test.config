/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        pixi run nextflow run . -profile test,monash,singularity \\
            --outdir /fs04/scratch2/xy86/sanjay/ipg-test-results

    The test profile consumes a locally-built chr22-subset bundle under
    /fs04/scratch2/xy86/sanjay/ipg-test-data/ produced by
    `bin/build_test_bundle.sh`. The bundle is derived from the real Monash
    GRCh38 reference and a real D100-liver FASTQ sample so it exercises the
    full pipeline end-to-end in ~15 minutes instead of 2-6 hours.

    See bin/build_test_bundle.sh and .claude/DECISIONS.md ADR-010 for
    rationale and rebuild instructions.
----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus:   4,
        memory: '14.GB',
        time:   '1.h'
    ]
}

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'chr22-subset test bundle built from real D100-liver sample and GRCh38 reference'

    // Override on the command line if you built the bundle somewhere else:
    //   --test_bundle /some/other/path
    test_bundle = '/fs04/scratch2/xy86/sanjay/ipg-test-data'

    // --- Input samplesheet (chr22-subsampled D100-liver) ---
    input = "${params.test_bundle}/samplesheet_test.csv"

    // --- Reference genome bundle (chr22 only) ---
    fasta       = "${params.test_bundle}/reference/GRCh38.chr22.fa"
    fasta_fai   = "${params.test_bundle}/reference/GRCh38.chr22.fa.fai"
    fasta_dict  = "${params.test_bundle}/reference/GRCh38.chr22.dict"
    gtf         = "${params.test_bundle}/reference/gencode.v44.chr22.gtf"
    star_index  = "${params.test_bundle}/reference/star_index_chr22"
    rseqc_bed   = "${params.test_bundle}/reference/gencode_assembly.chr22.bed"

    // --- BQSR known-sites (chr22-subset of the Broad/Mills/dbSNP bundle) ---
    dbsnp             = "${params.test_bundle}/variant_calling/dbsnp138.chr22.vcf.gz"
    dbsnp_tbi         = "${params.test_bundle}/variant_calling/dbsnp138.chr22.vcf.gz.tbi"
    known_indels      = "${params.test_bundle}/variant_calling/known_indels.chr22.vcf.gz"
    known_indels_tbi  = "${params.test_bundle}/variant_calling/known_indels.chr22.vcf.gz.tbi"
    mills             = "${params.test_bundle}/variant_calling/Mills.chr22.vcf.gz"
    mills_tbi         = "${params.test_bundle}/variant_calling/Mills.chr22.vcf.gz.tbi"

    // --- Mutect2 + GetPileupSummaries germline resource (chr22-subset) ---
    germline_resource      = "${params.test_bundle}/variant_calling/small_exac_common_3.chr22.vcf.gz"
    germline_resource_tbi  = "${params.test_bundle}/variant_calling/small_exac_common_3.chr22.vcf.gz.tbi"

    // Disable genome auto-fetch; we use explicit paths only.
    genome = null
}
