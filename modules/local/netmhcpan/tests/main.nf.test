nextflow_process {

    name "Test Process NETMHCPAN"
    script "../main.nf"
    process "NETMHCPAN"

    tag "modules"
    tag "modules_local"
    tag "netmhcpan"
    tag "stub"

    test("netmhcpan - stub") {
        options "-stub"
        when {
            process {
                """
                def pep = file("\${workDir}/peptides.tsv"); pep.text = "PEPTIDE\\n"
                def bin = file("\${workDir}/netMHCpan");    bin.text = "stub"
                input[0] = [ [ id:'test' ], pep ]
                input[1] = 'HLA-A01:01,HLA-B07:02'
                input[2] = bin
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
