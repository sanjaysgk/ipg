nextflow_process {

    name "Test Process SAGE"
    script "../main.nf"
    process "SAGE"

    tag "modules"
    tag "modules_local"
    tag "sage"
    tag "stub"

    test("sage - stub") {

        options "-stub"

        when {
            process {
                """
                def mzml = file("\${workDir}/sample.mzML"); mzml.text = "stub\\n"
                def fasta = file("\${workDir}/ref.fasta"); fasta.text = ">chr\\nACGT\\n"
                def cfg = file("\${workDir}/sage.json"); cfg.text = "{}\\n"
                def nofile = file("\${workDir}/NO_FILE"); nofile.text = ""
                input[0] = [ [ id:'test' ], [ mzml ] ]
                input[1] = fasta
                input[2] = cfg
                input[3] = nofile
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
