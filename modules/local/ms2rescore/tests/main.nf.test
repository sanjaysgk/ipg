nextflow_process {

    name "Test Process MS2RESCORE"
    script "../main.nf"
    process "MS2RESCORE"

    tag "modules"
    tag "modules_local"
    tag "ms2rescore"
    tag "stub"

    test("ms2rescore - stub") {
        options "-stub"
        when {
            process {
                """
                def pin    = file("\${workDir}/test.pin");        pin.text    = "stub\\n"
                def pkl    = file("\${workDir}/sample.scans.pkl"); pkl.text   = "stub\\n"
                def mgf    = file("\${workDir}/sample.mgf");       mgf.text   = "stub\\n"
                def cfg    = file("\${workDir}/ms2rescore.json");  cfg.text   = "{}\\n"
                input[0] = [ [ id:'test' ], pin ]
                input[1] = 'msfragger'
                input[2] = [ pkl ]
                input[3] = [ mgf ]
                input[4] = cfg
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
