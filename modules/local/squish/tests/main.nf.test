nextflow_process {

    name "Test Process SQUISH"
    script "../main.nf"
    process "SQUISH"

    tag "modules"
    tag "modules_local"
    tag "squish"

    test("squish - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    [
                        file('ref_3translate.fasta'),
                        file('unmasked_3translate.fasta'),
                        file('indel_3translate.fasta')
                    ]
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
