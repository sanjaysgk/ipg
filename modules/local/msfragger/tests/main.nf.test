nextflow_process {

    name "Test Process MSFRAGGER"
    script "../main.nf"
    process "MSFRAGGER"

    tag "modules"
    tag "modules_local"
    tag "msfragger"
    tag "stub"

    test("msfragger - stub") {

        options "-stub"

        when {
            process {
                """
                def ms1 = file("\${workDir}/sample.mzML"); ms1.text = "stub\\n"
                def fasta = file("\${workDir}/ref.fasta"); fasta.text = ">chr\\nACGT\\n"
                def nofile = file("\${workDir}/NO_FILE"); nofile.text = ""
                def params_file = file("\${workDir}/fragger.params"); params_file.text = "your_fasta\\n"
                input[0] = [ [ id:'test' ], [ ms1 ] ]
                input[1] = fasta
                input[2] = nofile
                input[3] = params_file
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
