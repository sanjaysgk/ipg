nextflow_process {

    name "Test Process COMBINE_FASTA"
    script "../main.nf"
    process "COMBINE_FASTA"

    tag "modules"
    tag "modules_local"
    tag "combine_fasta"
    tag "stub"

    // Concatenate a canonical (sp|) FASTA with a cryptic (TCONS_) FASTA; both
    // records must survive (no dedup) so INTEGRATE can class by accession prefix.
    test("combine canonical + cryptic - stub") {
        options "-stub"
        when {
            process {
                """
                def canon = file("\${workDir}/canonical.fasta")
                canon.text = ">sp|P12345|TEST_HUMAN canonical\\nMAAAKLDEKR\\n"
                def cryptic = file("\${workDir}/cryptic.fasta")
                cryptic.text = ">TCONS_00000001_f1p1_1 cryptic\\nPEPTIDESTUBKR\\n"
                input[0] = [ [ id:'test' ], [ canon, cryptic ] ]
                """
            }
        }
        then {
            def out = path(process.out.fasta.get(0).get(1))
            assertAll(
                { assert process.success },
                { assert out.readLines().findAll { it.startsWith('>') }.size() == 2 },
                { assert out.text.contains('sp|P12345|TEST_HUMAN') },
                { assert out.text.contains('TCONS_00000001_f1p1_1') },
            )
        }
    }
}
