nextflow_process {

    name "Test Process CURATE_VCF"
    script "../main.nf"
    process "CURATE_VCF"

    tag "modules"
    tag "modules_local"
    tag "curate_vcf"

    test("curate_vcf - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file('test.vcf')
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
