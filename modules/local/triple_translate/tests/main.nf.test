nextflow_process {

    name "Test Process TRIPLE_TRANSLATE"
    script "../main.nf"
    process "TRIPLE_TRANSLATE"

    tag "modules"
    tag "modules_local"
    tag "triple_translate"

    test("triple_translate - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file('test_transcriptome.fa'),
                    file('test.tracking')
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
