nextflow_process {

    name "Test Process GATK4_VALIDATESAMFILE"
    script "../main.nf"
    process "GATK4_VALIDATESAMFILE"

    tag "modules"
    tag "modules_local"
    tag "gatk4_validatesamfile"

    test("gatk4_validatesamfile - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [ [ id:'test' ], file('test.bam') ]
                input[1] = [ [ id:'reference' ], file('reference.fasta') ]
                input[2] = [ [ id:'reference' ], file('reference.fasta.fai') ]
                input[3] = [ [ id:'reference' ], file('reference.dict') ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
