nextflow_process {

    name "Test Process COMET"
    script "../main.nf"
    process "COMET"

    tag "modules"
    tag "modules_local"
    tag "comet"
    tag "stub"

    test("comet - stub") {

        options "-stub"

        when {
            process {
                """
                def mzml = file("\${workDir}/sample.mzML"); mzml.text = "stub\\n"
                def fasta = file("\${workDir}/ref.fasta"); fasta.text = ">chr\\nACGT\\n"
                def params_file = file("\${workDir}/comet.params"); params_file.text = "[comet_enzyme_info]\\n"
                input[0] = [ [ id:'test' ], [ mzml ] ]
                input[1] = fasta
                input[2] = params_file
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
