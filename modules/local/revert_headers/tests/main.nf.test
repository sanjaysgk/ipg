nextflow_process {

    name "Test Process REVERT_HEADERS"
    script "../main.nf"
    process "REVERT_HEADERS"

    tag "modules"
    tag "modules_local"
    tag "revert_headers"

    test("revert_headers - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file('alt.fasta')
                ]
                input[1] = file('reference.fasta')
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
