nextflow_process {

    name "Test Process IMMUNOINFORMATICS_REPORT"
    script "../main.nf"
    process "IMMUNOINFORMATICS_REPORT"

    tag "modules"
    tag "modules_local"
    tag "immunoinformatics_report"
    tag "stub"

    test("immunoinformatics_report - stub") {
        options "-stub"
        when {
            process {
                """
                def pep     = file("\${workDir}/peptides.tsv");    pep.text     = "peptide\\n"
                def mhc1    = file("\${workDir}/mhc1.tsv");        mhc1.text    = "x\\n"
                def mhc2    = file("\${workDir}/mhc2.tsv");        mhc2.text    = "x\\n"
                def gibbs   = file("\${workDir}/gibbs_in.tsv");    gibbs.text   = "x\\n"
                def lfq     = file("\${workDir}/lfq.tsv");         lfq.text     = "x\\n"
                def blastp  = file("\${workDir}/blastp_in.tsv");   blastp.text  = "x\\n"
                input[0] = [ [ id:'test' ], pep, mhc1, mhc2, gibbs, lfq, blastp ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
