nextflow_process {

    name "Test Process MOKAPOT"
    script "../main.nf"
    process "MOKAPOT"

    tag "modules"
    tag "modules_local"
    tag "mokapot"
    tag "stub"

    test("mokapot - stub") {
        options "-stub"
        when {
            process {
                """
                def pin = file("\${workDir}/test.pin"); pin.text = "stub\\n"
                input[0] = [ [ id:'test' ], [ pin ] ]
                input[1] = 'msfragger'
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
