nextflow_process {

    name "Test Process GFF3SORT"
    script "../main.nf"
    process "GFF3SORT"

    tag "modules"
    tag "modules_local"
    tag "gff3sort"

    test("gff3sort - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file('test.gtf')
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
