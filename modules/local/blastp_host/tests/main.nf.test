nextflow_process {

    name "Test Process BLASTP_HOST"
    script "../main.nf"
    process "BLASTP_HOST"

    tag "modules"
    tag "modules_local"
    tag "blastp_host"
    tag "stub"

    test("blastp_host - stub") {
        options "-stub"
        when {
            process {
                """
                def pep = file("\${workDir}/peptides.tsv"); pep.text = "PEPTIDE\\n"
                def db  = file("\${workDir}/human.phr");    db.text  = "stub"
                input[0] = [ [ id:'test' ], pep ]
                input[1] = [ db ]
                input[2] = 'human'
                input[3] = 'HUMAN'
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
