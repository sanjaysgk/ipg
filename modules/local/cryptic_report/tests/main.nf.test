nextflow_process {

    name "Test Process CRYPTIC_REPORT"
    script "../main.nf"
    process "CRYPTIC_REPORT"

    tag "modules"
    tag "modules_local"
    tag "cryptic_report"
    tag "stub"

    test("cryptic_report - stub") {
        options "-stub"
        when {
            process {
                """
                def pep = file("\${workDir}/integrated_peptides.tsv"); pep.text = "peptide\\tclass\\n"
                def res = file("\${workDir}/comet.psms.tsv");          res.text = "peptide\\n"
                input[0] = [ [ id:'test' ], pep, [ res ] ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
