nextflow_process {

    name "Test Process GIBBSCLUSTER"
    script "../main.nf"
    process "GIBBSCLUSTER"

    tag "modules"
    tag "modules_local"
    tag "gibbscluster"
    tag "stub"

    test("gibbscluster - stub") {
        options "-stub"
        when {
            process {
                """
                def pep = file("\${workDir}/peptides.tsv");        pep.text = "PEPTIDE\\n"
                def pl  = file("\${workDir}/GibbsCluster-2.0e_SA.pl"); pl.text = "stub"
                input[0] = [ [ id:'test' ], pep ]
                input[1] = pl
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
