nextflow_process {

    name "Test Process DB_COMPARE"
    script "../main.nf"
    process "DB_COMPARE"

    tag "modules"
    tag "modules_local"
    tag "db_compare"
    tag "stub"

    test("db_compare - stub") {
        options "-stub"
        when {
            process {
                """
                def cryptic = file("\${workDir}/cryptic.tsv"); cryptic.text = "peptide\\n"
                def uniprot = file("\${workDir}/uniprot.tsv"); uniprot.text = "peptide\\n"
                def discard = file("\${workDir}/discard.list"); discard.text = "x\\n"
                def unconv  = file("\${workDir}/unconv.list");  unconv.text  = "y\\n"
                input[0] = [ [ id:'test' ], cryptic, uniprot ]
                input[1] = discard
                input[2] = unconv
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
